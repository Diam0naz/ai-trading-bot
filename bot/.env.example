# ── CoinGecko (market data) ──────────────────────────────────
# Leave blank for the free tier (~30 req/min). For higher limits,
# create a free Demo API key at coingecko.com and paste it here.
COINGECKO_API_KEY=

# ── Binance (order execution only) ───────────────────────────
# CoinGecko cannot place trades, so Binance is still used to execute orders.
BINANCE_API_KEY=your_testnet_api_key
BINANCE_SECRET=your_testnet_secret
BINANCE_TESTNET=true

# ── Database — must point to the shared SQLite file ──────────
DATABASE_PATH=db/trading_bot.db

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHANNEL_ID=@your_channel_username

# ── Trading config ───────────────────────────────────────────
SYMBOL=BTC/USDT
# CoinGecko fixes candle granularity by window. Supported: 30m, 4h, 4d.
# 4h is recommended (enough history for the 50-period indicators).
TIMEFRAME=4h
SIGNAL_THRESHOLD=0.65
MAX_DAILY_LOSS_PCT=0.05
POSITION_SIZE_PCT=0.02
ATR_MULTIPLIER_SL=1.5
ATR_MULTIPLIER_TP=2.5

# ── Paths (resolved relative to project root at startup) ─────
MODEL_PATH=bot/model/xgb_signal_model.joblib
LOG_PATH=logs/bot.log
